# Environment (development, production, test)
# Use APP_ENV to avoid conflicts with the system ENV variable on Railway
APP_ENV=development

# Database
# Railway injects DATABASE_URL automatically — set either DATABASE_URL or DB_URL.
# Leave both unset locally to fall back to SQLite (sqlite:///./mmotor.db).
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_URL=postgresql://mmotor:mmotor123@localhost:5432/mmotor_db

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# App
APP_NAME=M-Motor API
APP_VERSION=1.0.0
DEBUG=false

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
ALLOWED_UPLOAD_EXTENSIONS=[".pdf",".jpg",".jpeg",".png"]
ALLOWED_MIME_TYPES=["application/pdf","image/jpeg","image/jpg","image/png"]
